<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false">
<html>
<head>
    <meta charset="UTF-8"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        body { padding: 8px; display: flex; align-items: center; justify-content: center; height: 100%; background: #fff; }
        .open-btn {
            background: #2e7d32;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }
        .open-btn:hover { background: #256427; }
    </style>
</head>
<body>
    <button class="open-btn" id="openBtn" onclick="openSoftphone()">📞 Open Softphone</button>

    <script>
        var softphoneWin = null;
        var INTAKE_PREFIX = 'a00'; // your Intake__c key prefix

        function getCurrentIntakeId() {
            try {
                var parentUrl = window.parent.location.href;
                console.log('Parent URL:', parentUrl);

                // Match /lightning/r/Intake__c/<Id>/view or similar
                var match = parentUrl.match(/\/r\/[A-Za-z0-9_]+\/([a-zA-Z0-9]{15,18})\//);
                if (match && match[1] && match[1].indexOf(INTAKE_PREFIX) === 0) {
                    return match[1];
                }

                // Fallback: scan for any 15/18-char Id starting with prefix anywhere in URL
                var idMatch = parentUrl.match(new RegExp(INTAKE_PREFIX + '[a-zA-Z0-9]{12,15}'));
                if (idMatch) {
                    return idMatch[0];
                }
            } catch (e) {
                console.log('Cannot read parent URL (cross-origin):', e.message);
            }
            return null;
        }

        function openSoftphone() {
            if (softphoneWin && !softphoneWin.closed) {
                softphoneWin.focus();
                return;
            }

            var intakeId = getCurrentIntakeId();
            console.log('Detected Intake ID:', intakeId);

            var url = '{!$Page.TwilioSoftphone}';
            if (intakeId) {
                url += '?intakeId=' + intakeId;
            }

            softphoneWin = window.open(
                url,
                'twilioSoftphone',
                'width=380,height=680,resizable=yes,alwaysRaised=yes'
            );

            var btn = document.getElementById('openBtn');
            btn.textContent = '📞 Softphone Open';

            var checkClosed = setInterval(function() {
                if (softphoneWin && softphoneWin.closed) {
                    btn.textContent = '📞 Open Softphone';
                    softphoneWin = null;
                    clearInterval(checkClosed);
                }
            }, 1000);
        }

        window.addEventListener('message', function(event) {
            if (!event.data || event.data.source !== 'twilio-softphone') return;
            console.log('Softphone event:', event.data.type, event.data.payload);
        });
    </script>
</body>
</html>
</apex:page>
<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Qualification_Score_Max_100</fullName>
    <active>true</active>
    <errorConditionFormula>Qualification_Score__c &gt; 100 || Qualification_Score__c &lt; 0</errorConditionFormula>
    <errorMessage>Qualification Score cannot be greater than 100.</errorMessage>
</ValidationRule>

<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <environments>Default</environments>
    <interviewLabel>Send Welcome Message {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Send Welcome Message</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Welcome_SMS</name>
        <label>Welcome SMS</label>
        <locationX>595</locationX>
        <locationY>389</locationY>
        <inputAssignments>
            <field>TwilioSF__Body__c</field>
            <value>
                <elementReference>WelcomeMessage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>TwilioSF__From_Number__c</field>
            <value>
                <stringValue>+15077650901</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>TwilioSF__To_Number__c</field>
            <value>
                <elementReference>$Record.Intake_Phone__c</elementReference>
            </value>
        </inputAssignments>
        <object>TwilioSF__Message__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>425</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Welcome_SMS</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Intake_Phone__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Intake__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>WelcomeMessage</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Welcome to the Delipat PI family! Thank you for placing your trust in us. We&apos;ll work hard on your behalf and keep you informed every step of the way. Reach out anytime—we&apos;re here to help.&lt;/p&gt;</text>
    </textTemplates>
</Flow>
